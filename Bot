# ------------------- КООРДИНАТНАЯ КАРТА -------------------
def generate_initial_map() -> list:
    grid = [["О" for _ in range(26)] for _ in range(20)]
    for y in range(3, 18):
        for x in range(3, 23):
            grid[y][x] = "С"
    for y in range(8, 13):
        for x in range(10, 16):
            grid[y][x] = "З"
    for y in range(5, 7):
        for x in range(18, 21):
            grid[y][x] = "Н"
    for y in range(2, 19):
        for x in range(2, 24):
            if grid[y][x] == "О":
                if (y > 2 and grid[y-1][x] == "С") or (y < 18 and grid[y+1][x] == "С") or \
                   (x > 2 and grid[y][x-1] == "С") or (x < 23 and grid[y][x+1] == "С"):
                    grid[y][x] = "П"
    return grid

def load_map() -> list:
    if not os.path.exists(MAP_FILE):
        grid = generate_initial_map()
        save_map(grid)
        return grid
    with open(MAP_FILE, "r", encoding="utf-8") as f:
        lines = [line.rstrip('\n') for line in f if line.strip() != '']
    grid = []
    for i, line in enumerate(lines):
        if i >= 20:
            break
        row = list(line.ljust(26, '.')[:26])
        grid.append(row)
    while len(grid) < 20:
        grid.append(["." for _ in range(26)])
    return grid

def save_map(grid: list):
    with open(MAP_FILE, "w", encoding="utf-8") as f:
        for row in grid:
            f.write("".join(row) + "\n")

def show_map() -> str:
    grid = load_map()
    header = "   " + " ".join([chr(65 + i) for i in range(26)])
    lines = [header]
    for i, row in enumerate(grid):
        y = i + 1
        line = f"{y:2} " + " ".join(row)
        lines.append(line)
    legend = "\n📚 Легенда: П - Побережье, С - Суша, О - Океан, Н - Небесная земля, З - Озеро с сушей"
    return "```\n" + "\n".join(lines) + "\n```" + legend

def set_tile(coord: str, symbol: str):
    if len(coord) < 2:
        return False, "Неверный формат координаты. Пример: A5"
    col_char = coord[0].upper()
    row_str = coord[1:]
    if not row_str.isdigit():
        return False, "Неверный номер строки."
    col = ord(col_char) - 65
    row = int(row_str) - 1
    if not (0 <= col < 26 and 0 <= row < 20):
        return False, "Координаты вне диапазона (A-Z, 1-20)."
    if len(symbol) > 1:
        symbol = symbol[0]
    grid = load_map()
    grid[row][col] = symbol
    save_map(grid)
    return True, f"Клетка {coord.upper()} теперь '{symbol}'."

