async def mute_user(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not can_mute(update.effective_user.id):
        await update.message.reply_text("⛔ Только ГМ или модератор может мутить.")
        return
    if update.effective_chat.type == "private":
        await update.message.reply_text("В личных сообщениях мут бессмысленен.")
        return
    if len(context.args) < 2:
        await update.message.reply_text("Использование: /mute @username минуты")
        return
    username = context.args[0]
    if not username.startswith('@'):
        username = '@' + username
    uid = get_user_id_by_username(username)
    if uid is None:
        await update.message.reply_text(f"Пользователь {username} не найден. Он должен написать сообщение в чат.")
        return
    try:
        minutes = int(context.args[1])
    except ValueError:
        await update.message.reply_text("Укажите целое число минут.")
        return
    if minutes <= 0 or minutes > 10080:
        await update.message.reply_text("Время мута от 1 до 10080 минут.")
        return
    until_date = datetime.utcnow() + timedelta(minutes=minutes)
    permissions = ChatPermissions(can_send_messages=False)
    try:
        await context.bot.restrict_chat_member(
            chat_id=update.effective_chat.id,
            user_id=uid,
            permissions=permissions,
            until_date=until_date
        )
        await update.message.reply_text(f"🔇 {username} замьючен на {minutes} минут.")
    except Exception as e:
        await update.message.reply_text(f"Не удалось замьютить: {e}")

