async def init_show(update: Update, context: ContextTypes.DEFAULT_TYPE):
    entries = load_initiative()
    if not entries:
        await update.message.reply_text("📜 Порядок хода пуст.")
        return
    parsed = []
    for e in entries:
        parts = e.rsplit(' ', 1)
        if len(parts) == 2:
            name, val = parts
            try:
                val = int(val)
                parsed.append((name, val))
            except ValueError:
                parsed.append((e, 0))
        else:
            parsed.append((e, 0))
    parsed.sort(key=lambda x: -x[1])
    lines = [f"{i+1}. {name} ({val})" for i, (name, val) in enumerate(parsed)]
    await update.message.reply_text("⚔️ *Порядок хода:*\n" + "\n".join(lines), parse_mode="Markdown")

