def roll_dice(expression: str) -> str:
    pattern = r'^(\d+)?d(\d+)([+-]\d+)?$'
    match = re.match(pattern, expression.lower().strip())
    if not match:
        return None
    num = int(match.group(1)) if match.group(1) else 1
    sides = int(match.group(2))
    mod_str = match.group(3)
    mod = int(mod_str) if mod_str else 0
    if num < 1 or num > 100 or sides < 2 or sides > 1000:
        return "Слишком экстремально."
    rolls = [random.randint(1, sides) for _ in range(num)]
    total = sum(rolls) + mod
    rolls_str = ', '.join(str(r) for r in rolls)
    mod_part = f" {mod:+d}" if mod else ""
    return f"{total} (🎲 {rolls_str}{mod_part})"

# ------------------- ШКАЛА ОПЫТА -------------------
def xp_bar(current_xp, max_xp=100, length=10):
    filled = int((current_xp / max_xp) * length)
    bar = "[" + "#" * filled + "-" * (length - filled) + "]"
    return f"{current_xp}/{max_xp} XP {bar}"

def check_level_up(player_data):
    while player_data["xp"] >= 100:
        player_data["xp"] -= 100
        player_data["level"] += 1
    return player_data

