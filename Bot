def load_players() -> dict:
    players = {}
    if os.path.exists(DB_FILE):
        with open(DB_FILE, "r", encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                parts = line.split(";")
                if len(parts) < 4:
                    continue
                name = parts[0]
                hp = int(parts[1])
                mental = int(parts[2])
                effects = parts[3].split(",") if parts[3] else []
                stats = {"str": 10, "dex": 10, "con": 10, "int": 10, "wis": 10, "cha": 10}
                if len(parts) >= 10:
                    try:
                        stats["str"] = int(parts[4])
                        stats["dex"] = int(parts[5])
                        stats["con"] = int(parts[6])
                        stats["int"] = int(parts[7])
                        stats["wis"] = int(parts[8])
                        stats["cha"] = int(parts[9])
                    except ValueError:
                        pass
                level = 1
                xp = 0
                if len(parts) >= 12:
                    try:
                        level = int(parts[10])
                        xp = int(parts[11])
                    except ValueError:
                        level = 1
                        xp = 0
                players[name.lower()] = {
                    "display_name": name,
                    "hp": hp,
                    "mental": mental,
                    "effects": [e for e in effects if e],
                    "stats": stats,
                    "level": level,
                    "xp": xp
                }
    return players

def save_players(players: dict):
    with open(DB_FILE, "w", encoding="utf-8") as f:
        for data in players.values():
            name = data["display_name"]
            hp = data["hp"]
            mental = data["mental"]
            effects_str = ",".join(data["effects"])
            s = data["stats"]
            level = data["level"]
            xp = data["xp"]
            f.write(f"{name};{hp};{mental};{effects_str};{s['str']};{s['dex']};{s['con']};{s['int']};{s['wis']};{s['cha']};{level};{xp}\n")

