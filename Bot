# ------------------- ИГРОВОЕ ВРЕМЯ (К407, непрерывный ход) -------------------
def load_game_time() -> dict:
    if not os.path.exists(TIME_FILE):
        now_ts = datetime.now().timestamp()
        init_game_minutes = ((407 - 1) * 360 + 0) * 24 * 60   # К407, день 1, месяц 1, 00:00
        with open(TIME_FILE, "w", encoding="utf-8") as f:
            f.write(f"{now_ts};{init_game_minutes}")
        return {"real_ts": now_ts, "game_minutes": init_game_minutes}
    with open(TIME_FILE, "r", encoding="utf-8") as f:
        parts = f.readline().strip().split(";")
        if len(parts) == 2:
            try:
                real_ts = float(parts[0])
                game_min = int(parts[1])
                return {"real_ts": real_ts, "game_minutes": game_min}
            except:
                pass
    now_ts = datetime.now().timestamp()
    init_game_minutes = ((407 - 1) * 360 + 0) * 24 * 60
    save_game_time(now_ts, init_game_minutes)
    return {"real_ts": now_ts, "game_minutes": init_game_minutes}

def save_game_time(real_ts: float, game_minutes: int):
    with open(TIME_FILE, "w", encoding="utf-8") as f:
        f.write(f"{real_ts};{game_minutes}")

def calculate_current_game_time():
    data = load_game_time()
    real_ts = data["real_ts"]
    base_game_min = data["game_minutes"]
    now_ts = datetime.now().timestamp()
    diff_real_sec = now_ts - real_ts
    if diff_real_sec < 0:
        diff_real_sec = 0
    # 1 реальная минута = 7 игровых минут
    game_min_added = int((diff_real_sec / 60.0) * 7)
    total_game_min = base_game_min + game_min_added

    total_days = total_game_min // (24 * 60)
    minutes_today = total_game_min % (24 * 60)
    hour = minutes_today // 60
    minute = minutes_today % 60
    minute = (minute // 10) * 10   # округляем до десятков

    year = total_days // 360 + 1
    remainder = total_days % 360
    month = remainder // 30 + 1
    day = remainder % 30 + 1
    return year, month, day, hour, minute

def format_game_time(year, month, day, hour, minute):
    return f"📅 День {day}, Месяц {month}, К{year}  ⏰ {hour:02d}:{minute:02d}"

